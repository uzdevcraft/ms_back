{
  "name": "telegram-marketplace-api",
  "version": "1.0.0",
  "private": true,
  "description": "Main Backend API for Telegram Marketplace (REST, PostgreSQL)",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "prisma migrate deploy && node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:ensure-users": "prisma db execute --file prisma/scripts/create_users_if_missing.sql --schema prisma/schema.prisma",
    "db:studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.2",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^6.7.0",
    "prisma": "^6.7.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.2",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^4.0.2",
    "pino": "^9.6.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "pino-pretty": "^13.0.0",
    "@types/node": "^22.15.17",
    "eslint": "^9.26.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}

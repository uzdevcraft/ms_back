NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

DATABASE_URL=postgresql://app:app@localhost:5433/telegram_marketplace?schema=public

# Same token as in BotFather (used to validate WebApp initData HMAC)
TELEGRAM_BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# JWT for WebApp session after successful initData validation
JWT_SECRET=change-me-to-another-long-random-string
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins (empty = reflect request origin in dev only; set explicitly in prod)
CORS_ORIGINS=

# Render sets RENDER=true; NODE_ENV becomes production when NODE_ENV is unset (see src/config/env.ts).
# Optional: force trust proxy for Fastify behind another LB (otherwise RENDER=true enables it).
# TRUST_PROXY=true

# Optional: comma-separated admin telegram user IDs (BigInt as string) for bootstrap / emergency access
BOOTSTRAP_ADMIN_TELEGRAM_IDS=

# Set true to expose /docs in production (keep false unless protected by network policy)
DOCS_ENABLED=true
